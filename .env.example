# 🛸 CryptoStream AI - .env Template
# Copy this to .env and fill in your actual credentials

# --- AI Intelligence ---
# Get your key at: https://aistudio.google.com/
GEMINI_API_KEY=YOUR_GEMINI_KEY_HERE
MODEL_ID=gemini-2.5-flash

# --- Infrastructure ---
DATABASE_URL=postgresql://postgres:institutional-secret@localhost:5432/crypto_db
KAFKA_BROKER=localhost:9092

# --- Security & Auth ---
MCP_API_KEY=LOCAL_DEV_KEY_CHANGE_ME
APP_API_KEY=institutional-secret-key

# --- GCP Configuration (Optional - for BigQuery Archive) ---
# Ensure your key file is named gcp-key.json (auto-ignored by git)
GCS_BUCKET_NAME=crypto-stream-lake-01
GCP_PROJECT_ID=your-project-id
