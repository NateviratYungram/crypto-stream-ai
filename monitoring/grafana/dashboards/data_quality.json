{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "type": "datasource",
      "pluginId": "prometheus"
    }
  ],
  "title": "CryptoStream AI — Data Quality Dashboard",
  "uid": "cryptostream-dq",
  "description": "Banking-grade DQ monitoring: Pass rates, error patterns, DLQ trends, and regulatory audit readiness.",
  "tags": ["cryptostream", "data-quality", "banking", "amlo"],
  "schemaVersion": 38,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "gauge",
      "title": "DQ Pass Rate — Last 5 min",
      "description": "BOT/AMLO Requirement: Maintain > 95% pass rate. Below 90% triggers regulatory escalation.",
      "gridPos": { "x": 0, "y": 0, "w": 8, "h": 8 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "minVizWidth": 75,
        "minVizHeight": 75,
        "orientation": "auto",
        "showThresholdLabels": true,
        "showThresholdMarkers": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 90 },
              { "color": "green", "value": 95 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "100 * rate(cryptostream_dq_passed_records_total[5m]) / (rate(cryptostream_dq_passed_records_total[5m]) + rate(cryptostream_dq_failed_records_total[5m]))",
          "legendFormat": "Pass Rate %"
        }
      ]
    },
    {
      "id": 2,
      "type": "piechart",
      "title": "DQ Failure Reasons Breakdown",
      "description": "Distribution of why trades fail validation. Most common reason indicates root cause.",
      "gridPos": { "x": 8, "y": 0, "w": 8, "h": 8 },
      "options": { "pieType": "donut", "displayLabels": ["name", "percent"] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum by (error_reason) (rate(cryptostream_dq_failed_records_total[1h]))",
          "legendFormat": "{{ error_reason }}"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Total DLQ Records (Today)",
      "description": "Total records routed to Dead Letter Queue today. Audit trail for AMLO investigation.",
      "gridPos": { "x": 16, "y": 0, "w": 8, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 100 },
              { "color": "red", "value": 1000 }
            ]
          },
          "displayName": "DLQ Records"
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "increase(cryptostream_dq_failed_records_total[24h])",
          "legendFormat": "DLQ Today"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Records Processed Today",
      "gridPos": { "x": 16, "y": 4, "w": 8, "h": 4 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "fixed", "fixedColor": "blue" },
          "displayName": "Total Processed"
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "increase(cryptostream_dq_passed_records_total[24h]) + increase(cryptostream_dq_failed_records_total[24h])",
          "legendFormat": "Total"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "DQ Pass vs. Fail Rate (records/min)",
      "description": "Real-time view of valid vs. invalid trades per minute. Should maintain near-zero failures.",
      "gridPos": { "x": 0, "y": 8, "w": 24, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "DQ Failed /min" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }] }
        ]
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rate(cryptostream_dq_passed_records_total[1m]) * 60",
          "legendFormat": "DQ Passed /min"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rate(cryptostream_dq_failed_records_total[1m]) * 60",
          "legendFormat": "DQ Failed /min"
        }
      ]
    }
  ]
}
